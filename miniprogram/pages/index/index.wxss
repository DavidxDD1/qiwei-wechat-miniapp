.index-page {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 32px;
}

.brand-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
  margin-top: 8px;
  padding: 24px 20px;
  border-radius: 24px;
  background:
    radial-gradient(circle at top, rgba(0, 245, 160, 0.16), transparent 42%),
    linear-gradient(180deg, rgba(23, 26, 33, 0.88), rgba(15, 17, 21, 0.96));
  box-shadow: var(--shadow-card);
}

.brand-logo-image {
  width: 168px;
  height: 168px;
  padding: 8px;
  border-radius: 24px;
  background: rgba(255, 255, 255, 0.96);
  box-shadow:
    0 14px 30px rgba(0, 0, 0, 0.32),
    0 0 0 1px rgba(255, 255, 255, 0.06);
}

.brand-panel__english {
  color: var(--text-secondary);
  font-size: 12px;
  letter-spacing: 4px;
}

.feature-section {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.feature-grid {
  display: flex;
  gap: 12px;
}

.feature-grid__item {
  flex: 1;
}

.index-page__cta {
  margin-top: auto;
}
