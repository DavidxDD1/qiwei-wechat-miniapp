.service-page {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.service-page__section {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.service-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.service-list__item,
.tier-grid__item {
  width: 100%;
}

.mode-scroll {
  width: 100%;
  white-space: nowrap;
}

.mode-scroll__inner {
  display: inline-flex;
  gap: 12px;
  padding-right: 20px;
}

.mode-scroll__item {
  flex: none;
}

.tier-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
}

.tier-grid__item {
  width: calc(50% - 8px);
}
