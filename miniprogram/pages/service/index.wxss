.service-page {
  gap: 18px;
}

.service-hero {
  padding: 20px;
  gap: 18px;
}

.service-hero__top {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: flex-start;
}

.service-hero__main {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.service-hero__eyebrow {
  color: var(--brand-highlight);
  font-size: var(--font-size-label);
  font-weight: 700;
  letter-spacing: 1.8px;
  text-transform: uppercase;
}

.service-hero__title {
  color: var(--text-primary);
  font-size: 26px;
  line-height: 1.2;
  font-weight: 700;
}

.service-hero__desc {
  color: var(--text-secondary);
  font-size: var(--font-size-body);
  line-height: var(--line-height-relaxed);
}

.service-hero__badge {
  flex: none;
  min-width: 96px;
  padding: 12px 14px;
  border-radius: 18px;
  border: 1px solid rgba(82, 242, 184, 0.18);
  background: rgba(82, 242, 184, 0.08);
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.service-hero__badge-value {
  color: var(--brand-primary);
  font-size: 15px;
  font-weight: 700;
}

.service-hero__badge-label {
  color: var(--text-tertiary);
  font-size: var(--font-size-label);
}

.service-hero__stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
}

.service-hero__stat {
  padding: 14px 12px;
  border-radius: 18px;
  background: rgba(8, 16, 30, 0.56);
  border: 1px solid rgba(130, 154, 184, 0.14);
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.service-hero__stat-value {
  color: var(--text-primary);
  font-size: var(--font-size-title);
  font-weight: 700;
}

.service-hero__stat-label {
  color: var(--text-tertiary);
  font-size: var(--font-size-caption);
}

.service-advisor {
  gap: 14px;
}

.service-advisor__top {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: flex-start;
}

.service-advisor__main {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.service-advisor__eyebrow {
  color: var(--brand-highlight);
  font-size: var(--font-size-label);
  font-weight: 700;
  letter-spacing: 1.6px;
  text-transform: uppercase;
}

.service-advisor__title {
  color: var(--text-primary);
  font-size: var(--font-size-title);
  font-weight: 700;
}

.service-advisor__desc,
.service-advisor__step {
  color: var(--text-secondary);
  font-size: var(--font-size-body);
  line-height: var(--line-height-body);
}

.service-advisor__status {
  flex: none;
  max-width: 116px;
  padding: 10px 12px;
  border-radius: 16px;
  border: 1px solid rgba(77, 189, 255, 0.16);
  background: rgba(77, 189, 255, 0.08);
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.service-advisor__status-value {
  color: var(--brand-secondary);
  font-size: var(--font-size-caption);
  font-weight: 700;
}

.service-advisor__status-label {
  color: var(--text-tertiary);
  font-size: var(--font-size-label);
  line-height: 1.4;
}

.service-advisor__tags {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8px;
}

.service-advisor__tag {
  min-width: 0;
  padding: 8px 10px;
  border-radius: 14px;
  border: 1px solid rgba(130, 154, 184, 0.14);
  background: rgba(8, 16, 30, 0.5);
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.service-advisor__tag-label {
  color: var(--text-tertiary);
  font-size: var(--font-size-label);
}

.service-advisor__tag-value {
  color: var(--text-primary);
  font-size: var(--font-size-caption);
  font-weight: 700;
}

.service-advisor__steps {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.service-selection {
  padding: 18px;
  gap: 12px;
}

.service-selection--active {
  border-color: rgba(82, 242, 184, 0.24);
  box-shadow: var(--shadow-glow);
}

.service-selection__top {
  display: flex;
  justify-content: space-between;
  gap: 16px;
  align-items: flex-start;
}

.service-selection__main {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.service-selection__eyebrow {
  color: var(--brand-highlight);
  font-size: var(--font-size-label);
  font-weight: 700;
  letter-spacing: 1.6px;
  text-transform: uppercase;
}

.service-selection__name {
  color: var(--text-primary);
  font-size: 17px;
  font-weight: 700;
  line-height: 1.6;
}

.service-selection__price {
  flex: none;
  color: var(--brand-primary);
  font-size: 22px;
  font-weight: 700;
  white-space: nowrap;
}

.service-selection__price--muted {
  color: var(--text-secondary);
}

.service-selection__desc {
  color: var(--text-secondary);
  font-size: var(--font-size-body);
  line-height: var(--line-height-body);
}

.service-selection__preview {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.service-selection__preview-item {
  padding: 6px 10px;
  border-radius: 999px;
  border: 1px solid rgba(77, 189, 255, 0.18);
  background: rgba(77, 189, 255, 0.08);
  color: var(--text-primary);
  font-size: var(--font-size-caption);
  line-height: 1.4;
}
