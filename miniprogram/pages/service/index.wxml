<view class="page-shell service-page">
  <view class="card service-hero">
    <view class="service-hero__top">
      <view class="service-hero__main">
        <text class="service-hero__eyebrow">{{activeServiceEyebrow}}</text>
        <text class="service-hero__title">{{activeServiceTitle}}</text>
        <text class="service-hero__desc">{{activeServiceDescription}}</text>
      </view>
      <view class="service-hero__badge">
        <text class="service-hero__badge-value">{{activeServiceBadge}}</text>
        <text class="service-hero__badge-label">当前视图</text>
      </view>
    </view>

    <view class="service-hero__stats">
      <view class="service-hero__stat" wx:for="{{serviceStats}}" wx:key="label">
        <text class="service-hero__stat-value">{{item.value}}</text>
        <text class="service-hero__stat-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <chip-tabs
    items="{{serviceTabs}}"
    active-id="{{activeServiceId}}"
    bind:select="handleServiceSelect"
  ></chip-tabs>

  <chip-tabs
    wx:if="{{subTabs.length}}"
    items="{{subTabs}}"
    active-id="{{activeTableId}}"
    variant="secondary"
    bind:select="handleSubSelect"
  ></chip-tabs>

  <view class="card service-selection {{selectedPrice ? 'service-selection--active' : ''}}">
    <view class="service-selection__top">
      <view class="service-selection__main">
        <text class="service-selection__eyebrow">{{selectionEyebrow}}</text>
        <text class="service-selection__name">{{selectionTitle}}</text>
      </view>
      <text class="service-selection__price {{selectedPrice ? '' : 'service-selection__price--muted'}}">{{selectionPriceText}}</text>
    </view>
    <text class="service-selection__desc">{{selectionDescription}}</text>
    <view class="service-selection__preview" wx:if="{{selectionPreviewItems.length}}">
      <text class="service-selection__preview-item" wx:for="{{selectionPreviewItems}}" wx:key="*this">{{item}}</text>
    </view>
  </view>

  <entry-offer-list
    wx:if="{{activeCard && activeCard.cardType === 'entry-group'}}"
    card="{{activeCard}}"
    selected-key="{{selectedKey}}"
    bind:select="handleCellTap"
    bind:buy="handleEntryBuy"
  ></entry-offer-list>

  <raw-table-card
    wx:elif="{{activeCard}}"
    card="{{activeCard}}"
    selected-key="{{selectedKey}}"
    bind:celltap="handleCellTap"
  ></raw-table-card>

  <empty-state
    wx:else
    title="暂无原表内容"
    desc="当前目录没有可渲染的价格表，请切换其他服务分类。"
  ></empty-state>

  <price-bar
    price="{{selectedPrice}}"
    display-name="{{selectedDisplay}}"
    disabled="{{!selectedPrice}}"
    primary-text="立即下单"
    secondary-text="加入购物车"
    show-secondary="{{true}}"
    bind:addcart="handleAddCart"
    bind:buy="handleBuy"
  ></price-bar>
</view>
