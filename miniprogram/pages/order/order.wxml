<view class="page-shell order-page">
  <view class="order-page__section">
    <section-title
      title="确认订单"
      subtitle="保持当前流程不变，仅升级为更清晰的视觉与填写体验"
    ></section-title>
    <view class="surface-card order-summary">
      <service-card
        title="{{serviceName}} - {{modeName}} - {{tierLabel}}"
        subtitle="当前已锁定套餐"
        hint="总价 ￥{{price}}"
        badge="已选组合"
        accent="待提交"
        selected="{{true}}"
      ></service-card>
      <view class="order-summary__tags">
        <mode-tag label="{{serviceName}}" selected="{{true}}"></mode-tag>
        <mode-tag label="{{modeName}}" selected="{{true}}"></mode-tag>
        <mode-tag label="{{tierLabel}}" selected="{{true}}"></mode-tag>
      </view>
    </view>
  </view>

  <view class="order-page__section">
    <section-title
      title="填写预约信息"
      subtitle="联系方式必填，提交后将生成订单号"
    ></section-title>
    <view class="surface-card form-panel">
      <view class="field-group">
        <text class="field-label">游戏ID</text>
        <input
          class="order-input {{focusedField === 'gameId' ? 'order-input--focused' : ''}}"
          placeholder="请输入游戏ID"
          placeholder-class="order-input__placeholder"
          data-field="gameId"
          bindinput="handleInput"
          bindfocus="handleFocus"
          bindblur="handleBlur"
          value="{{gameId}}"
        />
      </view>
      <view class="field-group">
        <text class="field-label">联系方式（必填）</text>
        <input
          class="order-input {{focusedField === 'contact' ? 'order-input--focused' : ''}}"
          placeholder="请输入手机号或微信号"
          placeholder-class="order-input__placeholder"
          data-field="contact"
          bindinput="handleInput"
          bindfocus="handleFocus"
          bindblur="handleBlur"
          value="{{contact}}"
        />
      </view>
    </view>
  </view>

  <button
    class="gradient-button order-submit"
    bindtap="handleSubmit"
    hover-class="is-pressing"
    hover-stay-time="150"
  >
    提交订单
  </button>
</view>
