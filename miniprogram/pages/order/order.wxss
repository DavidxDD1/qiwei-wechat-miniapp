.order-page {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.order-page__section {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.order-summary {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.order-summary__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.form-panel {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.field-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.field-label {
  color: var(--text-secondary);
  font-size: 14px;
  line-height: 1.5;
}

.order-input {
  width: 100%;
  height: 52px;
  padding: 0 16px;
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: var(--radius-button);
  background: rgba(11, 13, 17, 0.92);
  color: var(--text-primary);
  font-size: 14px;
  line-height: 52px;
  transition: box-shadow 200ms ease, border-color 200ms ease, transform 150ms ease;
}

.order-input--focused {
  border-color: rgba(0, 245, 160, 0.44);
  box-shadow: 0 0 0 2px rgba(0, 245, 160, 0.18);
}

.order-input__placeholder {
  color: var(--text-muted);
}

.order-submit {
  margin-top: 8px;
}
