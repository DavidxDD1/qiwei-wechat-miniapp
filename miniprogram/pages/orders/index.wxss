.orders-filters {
  width: 100%;
  white-space: nowrap;
}

.orders-filters__inner {
  display: inline-flex;
  gap: 10px;
  padding-right: 20px;
}

.orders-filters__button {
  min-width: 88px;
  padding: 0 16px;
  height: 40px;
  line-height: 40px;
  border-radius: 999px;
  border: 1px solid var(--border-color);
  background: rgba(17, 24, 38, 0.88);
  color: var(--text-secondary);
  font-size: 13px;
}

.orders-filters__button--active {
  border-color: rgba(82, 242, 184, 0.28);
  background:
    linear-gradient(180deg, rgba(82, 242, 184, 0.14), rgba(17, 24, 38, 0.92)),
    rgba(17, 24, 38, 0.92);
  color: var(--text-primary);
  box-shadow: 0 10px 22px rgba(82, 242, 184, 0.16);
  transform: scale(1.02);
}

.orders-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.orders-card__top {
  display: flex;
  justify-content: space-between;
  gap: 12px;
}

.orders-card__main {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.orders-card__order-no {
  color: var(--text-primary);
  font-size: var(--font-size-heading);
  font-weight: var(--font-weight-heading);
}

.orders-card__time,
.orders-card__contact,
.orders-card__item,
.orders-card__remark {
  color: var(--text-secondary);
  font-size: var(--font-size-body);
  line-height: var(--line-height-body);
}

.orders-card__amount {
  color: var(--brand-primary);
  font-size: 18px;
  font-weight: 700;
}

.orders-card__items {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
