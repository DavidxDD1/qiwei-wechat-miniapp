.orders-page {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.orders-filters {
  width: 100%;
  white-space: nowrap;
}

.orders-filters__inner {
  display: inline-flex;
  gap: 10px;
  padding-right: 20px;
}

.orders-filters__button {
  min-width: 88px;
  padding: 0 16px;
  height: 40px;
  line-height: 40px;
  border-radius: 999px;
  border: 1px solid #2A2F3A;
  background: #171A21;
  color: #A0A6B1;
  font-size: 13px;
}

.orders-filters__button--active {
  border: 2px solid #00F5A0;
  color: #FFFFFF;
  box-shadow: 0 0 20px rgba(0, 245, 160, 0.4);
  transform: scale(1.02);
}

.orders-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.orders-card {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.orders-card__top {
  display: flex;
  justify-content: space-between;
  gap: 12px;
}

.orders-card__main {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.orders-card__order-no {
  color: #FFFFFF;
  font-size: 16px;
  font-weight: 500;
}

.orders-card__time,
.orders-card__contact,
.orders-card__item,
.orders-card__remark {
  color: #A0A6B1;
  line-height: 1.7;
}

.orders-card__amount {
  color: #00F5A0;
  font-size: 18px;
  font-weight: 600;
}

.orders-card__items {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
