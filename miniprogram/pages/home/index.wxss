.home-page {
  display: flex;
  flex-direction: column;
  gap: 22px;
}

.home-section {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.home-entry-list,
.home-hot-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.home-entry-card,
.home-hot-card,
.home-panel,
.home-faq {
  padding: 18px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.home-entry-card__top,
.home-hot-card__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.home-entry-card__index,
.home-hot-card__index {
  color: var(--brand-highlight);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 1.4px;
}

.home-entry-card__action,
.home-hot-card__action {
  color: var(--text-secondary);
  font-size: 12px;
}

.home-entry-card__title,
.home-hot-card__title,
.home-faq__q {
  color: var(--text-primary);
  font-size: 18px;
  font-weight: 700;
  line-height: 1.4;
}

.home-hot-card__price {
  color: var(--brand-primary);
  font-size: 20px;
  font-weight: 700;
}

.home-entry-card__desc,
.home-hot-card__desc,
.home-summary__item,
.home-faq__a,
.home-panel__eyebrow,
.home-step__desc {
  color: var(--text-secondary);
  line-height: 1.7;
}

.home-hot-card__bottom {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  gap: 12px;
}

.home-insight-grid {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.home-panel__eyebrow {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1.6px;
  text-transform: uppercase;
}

.home-panel__title,
.home-step__title {
  color: var(--text-primary);
  font-size: 17px;
  font-weight: 700;
}

.home-step {
  display: flex;
  gap: 12px;
  align-items: flex-start;
}

.home-step__index {
  width: 28px;
  height: 28px;
  flex: none;
  border-radius: 50%;
  border: 1px solid rgba(82, 242, 184, 0.18);
  background: rgba(82, 242, 184, 0.08);
  color: var(--brand-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 700;
}

.home-step__main {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
