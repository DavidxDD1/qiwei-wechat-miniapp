.home-page {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.home-hero {
  padding: 24px 20px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.home-hero__logo {
  width: 140px;
  height: 140px;
  align-self: center;
}

.home-hero__subtitle {
  color: #A0A6B1;
  line-height: 1.8;
}

.home-hero__actions {
  display: flex;
  gap: 12px;
}

.home-hero__button {
  flex: 1;
}

.home-hero__button--single {
  width: 100%;
}

.home-section {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.home-hot-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.home-hot-card,
.home-summary,
.home-faq {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.home-hot-card__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
}

.home-hot-card__title,
.home-faq__q {
  color: #FFFFFF;
  font-size: 16px;
  font-weight: 500;
}

.home-hot-card__price {
  color: #00F5A0;
  font-size: 18px;
  font-weight: 600;
}

.home-hot-card__desc,
.home-summary__item,
.home-faq__a {
  color: #A0A6B1;
  line-height: 1.7;
}
