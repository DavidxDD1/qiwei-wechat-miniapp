<view class="page-shell page-stack home-page">
  <page-hero
    eyebrow="QIWEI ESPORTS"
    title="{{hero.title}}"
    desc="{{hero.subtitle}}"
    logo-src="/assets/logo.jpg"
    metrics="{{heroMetrics}}"
    primary-text="进入服务目录"
    secondary-text="查看个人中心"
    bind:primarytap="handleOpenService"
    bind:secondarytap="handleProfile"
  ></page-hero>

  <view class="home-section">
    <section-title
      eyebrow="Choose Faster"
      title="按需求进入服务"
      desc="{{hero.slogan}}"
    ></section-title>
    <view class="home-service-list">
      <view
        class="card panel-card home-service-card"
        wx:for="{{serviceEntrypoints}}"
        wx:key="id"
        data-service-id="{{item.serviceId}}"
        bindtap="handleServiceEntry"
        hover-class="is-pressing"
        hover-stay-time="120"
      >
        <view class="home-service-card__top">
          <text class="tag">{{item.badge}}</text>
          <text class="home-service-card__action">{{item.actionText}}</text>
        </view>
        <text class="home-service-card__intent">{{item.intent}}</text>
        <text class="home-service-card__title">{{item.title}}</text>
        <text class="home-service-card__desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <view class="home-trust-list">
    <view class="home-trust-item" wx:for="{{trustSignals}}" wx:key="id">
      <text class="home-trust-item__title">{{item.title}}</text>
      <text class="home-trust-item__desc">{{item.desc}}</text>
    </view>
  </view>

  <view class="home-section">
    <section-title
      eyebrow="Hot Sale"
      title="今日热销"
      desc="从店内服务里随机推荐几项热门内容，点卡片可直接去服务页继续选择。"
    ></section-title>
    <view class="home-hot-list">
      <view
        class="card panel-card home-hot-card"
        wx:for="{{hotSales}}"
        wx:key="id"
        bindtap="handleOpenService"
        hover-class="is-pressing"
        hover-stay-time="150"
      >
        <view class="home-hot-card__top">
          <text class="home-hot-card__index">0{{index + 1}}</text>
          <text class="tag">{{item.tag}}</text>
        </view>
        <text class="home-hot-card__title">{{item.title}}</text>
        <text class="home-hot-card__desc">{{item.subtitle}}</text>
        <view class="home-hot-card__bottom">
          <text class="home-hot-card__price">{{item.priceText}}</text>
          <text class="home-hot-card__action">立即锁定</text>
        </view>
      </view>
    </view>
  </view>

  <view class="home-insight-grid">
    <view class="card panel-card home-panel">
      <text class="home-panel__eyebrow">Flow</text>
      <text class="home-panel__title">下单流程</text>
      <view class="home-step" wx:for="{{journeySteps}}" wx:key="id">
        <view class="home-step__index">{{index + 1}}</view>
        <view class="home-step__main">
          <text class="home-step__title">{{item.title}}</text>
          <text class="home-step__desc">{{item.desc}}</text>
        </view>
      </view>
    </view>

    <view class="card panel-card home-panel">
      <text class="home-panel__eyebrow">Capability</text>
      <text class="home-panel__title">当前能力</text>
      <text class="home-summary__item" wx:for="{{serviceSummary}}" wx:key="*this">- {{item}}</text>
    </view>
  </view>

  <view class="home-section">
    <section-title
      eyebrow="FAQ"
      title="常见问题"
      desc="支付、客服、原表来源等关键说明都放在这里"
    ></section-title>
    <view class="card panel-card home-faq" wx:for="{{faq}}" wx:key="q">
      <text class="home-faq__q">{{item.q}}</text>
      <text class="home-faq__a">{{item.a}}</text>
    </view>
  </view>
</view>
