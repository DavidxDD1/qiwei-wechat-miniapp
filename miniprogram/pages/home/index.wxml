<view class="page-shell home-page">
  <view class="card home-hero">
    <image class="home-hero__logo" src="/assets/logo.jpg" mode="aspectFit"></image>
    <section-title
      title="{{hero.title}}"
      desc="{{hero.slogan}}"
    ></section-title>
    <text class="home-hero__subtitle">{{hero.subtitle}}</text>
    <button
      class="ghost-button home-hero__button home-hero__button--single"
      bindtap="handleProfile"
      hover-class="is-pressing"
      hover-stay-time="150"
    >
      查看个人中心
    </button>
  </view>

  <view class="home-section">
    <section-title
      title="今日热销"
      desc="从店内服务里随机推荐几项热门内容，点卡片可直接去服务页继续选择。"
    ></section-title>
    <view class="home-hot-list">
      <view
        class="card home-hot-card"
        wx:for="{{hotSales}}"
        wx:key="id"
        bindtap="handleOpenService"
        hover-class="is-pressing"
        hover-stay-time="150"
      >
        <view class="home-hot-card__top">
          <text class="tag">{{item.tag}}</text>
          <text class="home-hot-card__price">{{item.priceText}}</text>
        </view>
        <text class="home-hot-card__title">{{item.title}}</text>
        <text class="home-hot-card__desc">{{item.subtitle}}</text>
      </view>
    </view>
  </view>

  <view class="home-section">
    <section-title
      title="当前能力"
      desc="本地 Mock 全流程可跑，后续可升级到真实服务端"
    ></section-title>
    <view class="card home-summary">
      <text class="home-summary__item" wx:for="{{serviceSummary}}" wx:key="*this">- {{item}}</text>
    </view>
  </view>

  <view class="home-section">
    <section-title
      title="常见问题"
      desc="支付、客服、原表来源等关键说明都放在这里"
    ></section-title>
    <view class="card home-faq" wx:for="{{faq}}" wx:key="q">
      <text class="home-faq__q">{{item.q}}</text>
      <text class="home-faq__a">{{item.a}}</text>
    </view>
  </view>
</view>
