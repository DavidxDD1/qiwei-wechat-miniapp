.pay-info-card__top {
  display: flex;
  gap: 12px;
  justify-content: space-between;
}

.pay-info-card__main {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.pay-info-card__order-no,
.pay-info-card__title {
  color: var(--text-primary);
  font-size: var(--font-size-heading);
  font-weight: var(--font-weight-heading);
}

.pay-info-card__amount {
  color: var(--brand-primary);
  font-size: 20px;
  font-weight: 700;
}

.pay-info-card__items,
.pay-info-page__actions {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.pay-info-card__item,
.pay-info-card__desc {
  color: var(--text-secondary);
  font-size: var(--font-size-body);
  line-height: var(--line-height-body);
}
