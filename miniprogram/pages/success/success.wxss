.success-page {
  padding-top: 24px;
}

.success-panel {
  width: 100%;
  max-width: 420px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
  padding: 32px 24px;
  border-radius: 24px;
  background:
    radial-gradient(circle at top, rgba(0, 245, 160, 0.1), transparent 36%),
    rgba(23, 26, 33, 0.96);
  box-shadow: var(--shadow-card);
}

.success-icon {
  position: relative;
  width: 88px;
  height: 88px;
}

.success-icon__circle {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: linear-gradient(180deg, rgba(0, 245, 160, 0.18), rgba(0, 194, 255, 0.08));
  box-shadow: inset 0 0 0 1px rgba(0, 245, 160, 0.24);
}

.success-icon__check {
  position: absolute;
  top: 24px;
  left: 29px;
  width: 24px;
  height: 14px;
  border-bottom: 4px solid var(--brand-primary);
  border-left: 4px solid var(--brand-primary);
  transform: rotate(-45deg);
}

.success-panel__card {
  width: 100%;
}

.success-panel__meta {
  display: flex;
  justify-content: center;
}

.success-tip {
  color: var(--text-secondary);
  font-size: 14px;
  line-height: 1.7;
  text-align: center;
}
