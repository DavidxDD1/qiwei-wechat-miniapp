<view class="page-shell page-shell--center success-page">
  <view class="success-panel">
    <view class="success-icon">
      <view class="success-icon__circle"></view>
      <view class="success-icon__check"></view>
    </view>
    <section-title
      title="预约提交成功"
      subtitle="订单已生成，请尽快联系在线客服确认排单"
      align="center"
    ></section-title>
    <view class="success-panel__card">
      <service-card
        title="订单号"
        subtitle="{{orderId}}"
        hint="请保存订单号，便于客服核验"
        badge="已创建"
      ></service-card>
    </view>
    <view class="success-panel__meta">
      <mode-tag label="总价 ￥{{price}}" selected="{{true}}"></mode-tag>
    </view>
    <text class="success-tip">请联系客服确认预约信息</text>
  </view>
</view>
