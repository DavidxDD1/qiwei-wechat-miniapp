<view class="page success-page">
  <view class="panel">
    <text class="success-title">预约提交成功</text>
    <view class="summary-row">
      <text class="summary-label">订单号</text>
      <text class="summary-value">{{orderId}}</text>
    </view>
    <view class="summary-row">
      <text class="summary-label">价格</text>
      <text class="summary-value">¥{{price}}</text>
    </view>
    <text class="success-tip">请联系客服确认预约信息</text>
  </view>
</view>
