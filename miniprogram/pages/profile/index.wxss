.profile-page {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.profile-user {
  padding: 20px 16px;
  display: flex;
  align-items: center;
  gap: 14px;
}

.profile-user__avatar {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: linear-gradient(90deg, #00F5A0, #00C2FF);
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-user__avatar-text {
  color: #0F1115;
  font-size: 18px;
  font-weight: 700;
}

.profile-user__main {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.profile-user__name {
  color: #FFFFFF;
  font-size: 18px;
  font-weight: 500;
}

.profile-actions,
.profile-placeholder-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.profile-placeholder-card {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.profile-placeholder-card__top {
  display: flex;
  justify-content: space-between;
  gap: 12px;
}

.profile-placeholder-card__title {
  color: #FFFFFF;
  font-size: 16px;
  font-weight: 500;
}

.profile-placeholder-card__desc {
  color: #A0A6B1;
  line-height: 1.7;
}
