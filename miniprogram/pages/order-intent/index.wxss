.order-intent-card__title,
.order-form__title {
  color: var(--text-primary);
  font-size: var(--font-size-heading);
  font-weight: var(--font-weight-heading);
}

.order-intent-card__item {
  display: flex;
  gap: 12px;
  justify-content: space-between;
  align-items: flex-start;
}

.order-intent-card__name {
  min-width: 0;
  flex: 1;
  color: var(--text-secondary);
  font-size: var(--font-size-body);
  line-height: var(--line-height-body);
}

.order-intent-card__price,
.order-intent-card__total {
  color: var(--brand-primary);
  font-weight: 700;
}

.order-intent-card__total {
  align-self: flex-start;
  font-size: var(--font-size-heading);
}

.order-rules__text {
  color: var(--text-secondary);
  font-size: var(--font-size-body);
  line-height: var(--line-height-body);
}

.order-rules__button--active {
  border-color: rgba(82, 242, 184, 0.24);
  color: var(--brand-primary);
  background: rgba(82, 242, 184, 0.08);
}
