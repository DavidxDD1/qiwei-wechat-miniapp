.price-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  height: 72px;
  padding: 12px 20px;
  border-right: none;
  border-bottom: none;
  border-left: none;
  border-radius: 0;
  background: rgba(23, 26, 33, 0.98);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  z-index: 99;
}

.price-bar__meta {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.price-bar__label {
  color: #A0A6B1;
  font-size: 12px;
  line-height: 1.5;
}

.price-bar__value {
  color: #00F5A0;
  font-size: 20px;
  font-weight: 600;
}

.price-bar__actions {
  display: flex;
  gap: 8px;
}

.price-bar__button {
  min-width: 104px;
  padding: 0 14px;
}

.price-bar__button--disabled {
  opacity: 0.5;
}
