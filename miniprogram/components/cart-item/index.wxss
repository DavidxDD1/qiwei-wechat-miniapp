.cart-item {
  gap: 14px;
}

.cart-item__top {
  display: flex;
  gap: 12px;
  justify-content: space-between;
}

.cart-item__main {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.cart-item__title {
  color: var(--text-primary);
  font-size: var(--font-size-heading);
  font-weight: var(--font-weight-heading);
  line-height: 1.6;
}

.cart-item__price {
  color: var(--brand-primary);
  font-size: 18px;
  font-weight: 700;
}

.cart-item__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.cart-item__line {
  color: var(--text-secondary);
  font-size: var(--font-size-caption);
}

.cart-item__remark {
  min-height: 44px;
}

.cart-item__actions {
  display: flex;
  gap: 10px;
}

.cart-item__button {
  flex: 1;
}

.cart-item__button--danger {
  color: var(--danger);
}
