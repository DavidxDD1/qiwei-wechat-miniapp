.status-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 4px 10px;
  border-radius: 999px;
  font-size: 12px;
}

.status-badge--pending {
  background: rgba(0, 194, 255, 0.12);
  color: #00C2FF;
}

.status-badge--confirmed {
  background: rgba(0, 245, 160, 0.12);
  color: #00F5A0;
}

.status-badge--cancelled {
  background: rgba(255, 77, 79, 0.12);
  color: #FF4D4F;
}

.status-badge__text {
  line-height: 1.4;
}
