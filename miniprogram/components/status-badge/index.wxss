.status-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 5px 10px;
  border-radius: 999px;
  font-size: 12px;
  border: 1px solid transparent;
}

.status-badge--pending {
  background: rgba(77, 189, 255, 0.12);
  border-color: rgba(77, 189, 255, 0.18);
  color: var(--brand-secondary);
}

.status-badge--confirmed {
  background: rgba(82, 242, 184, 0.12);
  border-color: rgba(82, 242, 184, 0.18);
  color: var(--brand-primary);
}

.status-badge--cancelled {
  background: rgba(255, 90, 103, 0.12);
  border-color: rgba(255, 90, 103, 0.18);
  color: var(--danger);
}

.status-badge__dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: currentColor;
}

.status-badge__text {
  line-height: 1.4;
}
