.price-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-2);
  height: 72px;
  padding: 12px var(--page-padding-x);
  background: rgba(23, 26, 33, 0.98);
  box-shadow: 0 -8px 24px rgba(0, 0, 0, 0.28);
  z-index: 99;
}

.price-bar__meta {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.price-bar__label {
  color: var(--text-secondary);
  font-size: 14px;
  line-height: 1.4;
}

.price-bar__value {
  color: var(--brand-primary);
  font-size: 20px;
  font-weight: 600;
  line-height: 1.3;
}

.price-bar__button {
  width: 132px;
  height: 48px;
  border-radius: var(--radius-button);
  background: linear-gradient(90deg, #00F5A0, #00C2FF);
  color: #071017;
  font-size: 14px;
  font-weight: 600;
  line-height: 48px;
  text-align: center;
  transition: transform 150ms ease, opacity 150ms ease;
}

.price-bar__button--disabled {
  background: #2B313C;
  color: var(--text-muted);
  opacity: 0.5;
}
