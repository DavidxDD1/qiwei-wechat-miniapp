<view
  class="service-card {{selected ? 'service-card--selected' : ''}} {{disabled ? 'service-card--disabled' : ''}} {{compact ? 'service-card--compact' : ''}}"
  bindtap="handleTap"
  hover-class="{{disabled ? '' : 'is-pressing'}}"
  hover-start-time="20"
  hover-stay-time="150"
>
  <view class="service-card__meta" wx:if="{{badge || accent}}">
    <text class="service-card__badge" wx:if="{{badge}}">{{badge}}</text>
    <text class="service-card__accent" wx:if="{{accent}}">{{accent}}</text>
  </view>
  <text class="service-card__title">{{title}}</text>
  <text class="service-card__subtitle" wx:if="{{subtitle}}">{{subtitle}}</text>
  <text class="service-card__hint" wx:if="{{hint}}">{{hint}}</text>
</view>
