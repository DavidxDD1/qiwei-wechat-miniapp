.empty-state {
  padding: 24px 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  text-align: center;
}

.empty-state__title {
  color: #FFFFFF;
  font-size: 18px;
  font-weight: 500;
}

.empty-state__desc {
  color: #A0A6B1;
  font-size: 14px;
  line-height: 1.7;
}

.empty-state__button {
  width: 180px;
}
