.price-cell {
  min-height: 56px;
  padding: 12px;
  border-radius: 12px;
  border: 1px solid #2A2F3A;
  background: #141820;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 6px;
  transition: all 0.2s ease;
}

.price-cell--selected {
  border: 2px solid #00F5A0;
  box-shadow: 0 0 20px rgba(0, 245, 160, 0.4);
  transform: scale(1.02);
}

.price-cell--disabled {
  opacity: 0.45;
}

.price-cell__label {
  color: #A0A6B1;
  font-size: 12px;
}

.price-cell__value {
  color: #FFFFFF;
  font-size: 16px;
  font-weight: 600;
}
