<view
  class="price-cell {{selected ? 'price-cell--selected' : ''}} {{disabled ? 'price-cell--disabled' : ''}}"
  bindtap="handleTap"
  hover-class="{{disabled ? '' : 'is-pressing'}}"
  hover-stay-time="150"
>
  <view class="price-cell__top">
    <text class="price-cell__label">{{label}}</text>
    <text class="price-cell__badge" wx:if="{{selected}}">已选</text>
  </view>
  <text class="price-cell__value">{{priceText}}</text>
  <text class="price-cell__hint">{{disabled ? '当前不可选' : (selected ? '方案已锁定' : '点击锁定价格')}}</text>
</view>
