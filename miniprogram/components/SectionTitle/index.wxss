.section-title {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.section-title--center {
  align-items: center;
  text-align: center;
}

.section-title--left {
  align-items: flex-start;
  text-align: left;
}

.section-title__headline {
  color: var(--text-primary);
  font-size: 22px;
  font-weight: 600;
  line-height: 1.3;
}

.section-title__desc {
  color: var(--text-secondary);
  font-size: 14px;
  line-height: 1.6;
}
