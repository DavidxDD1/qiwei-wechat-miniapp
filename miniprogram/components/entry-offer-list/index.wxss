.entry-offer-list {
  padding: 18px;
  gap: 16px;
}

.entry-offer-list__header {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  align-items: flex-start;
}

.entry-offer-list__headline {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.entry-offer-list__title {
  color: var(--text-primary);
  font-size: var(--font-size-title);
  font-weight: 700;
}

.entry-offer-list__subtitle {
  color: var(--text-secondary);
  font-size: var(--font-size-meta);
  line-height: 1.6;
}

.entry-offer-list__summary {
  flex: none;
  padding: 10px 12px;
  border-radius: 16px;
  background: rgba(8, 16, 30, 0.54);
  border: 1px solid rgba(130, 154, 184, 0.14);
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.entry-offer-list__summary-value {
  color: var(--text-primary);
  font-size: var(--font-size-heading);
  font-weight: 700;
}

.entry-offer-list__summary-label {
  color: var(--text-tertiary);
  font-size: var(--font-size-label);
}

.entry-offer-list__grid {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.entry-offer-card {
  padding: 16px;
  border-radius: 18px;
  border: 1px solid rgba(130, 154, 184, 0.14);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.03), transparent 26%),
    rgba(8, 16, 30, 0.72);
  display: flex;
  flex-direction: column;
  gap: 12px;
  transition: transform 150ms ease, box-shadow 150ms ease, border-color 150ms ease;
}

.entry-offer-card--selected {
  border-color: rgba(82, 242, 184, 0.38);
  box-shadow: 0 14px 28px rgba(82, 242, 184, 0.14);
  transform: translateY(-2px);
}

.entry-offer-card__top {
  display: flex;
  justify-content: space-between;
  gap: 14px;
  align-items: flex-start;
}

.entry-offer-card__main {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.entry-offer-card__title {
  color: var(--text-primary);
  font-size: 17px;
  line-height: 1.5;
  font-weight: 700;
}

.entry-offer-card__summary {
  color: var(--text-secondary);
  font-size: 12px;
  line-height: 1.6;
}

.entry-offer-card__price-block {
  flex: none;
  min-width: 76px;
  display: flex;
  flex-direction: column;
  gap: 4px;
  align-items: flex-end;
}

.entry-offer-card__price {
  color: var(--brand-primary);
  font-size: 22px;
  font-weight: 700;
  white-space: nowrap;
}

.entry-offer-card__price-label {
  color: var(--text-tertiary);
  font-size: 11px;
}

.entry-offer-card__tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.entry-offer-card__tag {
  padding: 6px 10px;
  border-radius: 999px;
  border: 1px solid rgba(77, 189, 255, 0.16);
  background: rgba(77, 189, 255, 0.08);
  color: var(--text-primary);
  font-size: 11px;
  line-height: 1.3;
}

.entry-offer-card__footer {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  align-items: flex-end;
}

.entry-offer-card__meta {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.entry-offer-card__guarantee {
  color: var(--text-primary);
  font-size: 13px;
  font-weight: 600;
}

.entry-offer-card__hint {
  color: var(--text-tertiary);
  font-size: 11px;
  line-height: 1.5;
}

.entry-offer-card__button {
  min-width: 108px;
  padding: 0 14px;
}
