.section-title {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.section-title__top {
  display: flex;
  align-items: center;
  gap: 10px;
}

.section-title__eyebrow {
  color: var(--brand-highlight);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 1.6px;
  text-transform: uppercase;
}

.section-title__line {
  flex: 1;
  height: 1px;
  background: linear-gradient(90deg, rgba(77, 189, 255, 0.3), transparent);
}

.section-title__headline {
  color: var(--text-primary);
  font-size: 24px;
  line-height: 1.25;
  font-weight: 700;
}

.section-title__desc {
  color: var(--text-secondary);
  font-size: 14px;
  line-height: 1.75;
}
