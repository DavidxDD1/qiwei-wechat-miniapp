.tier-card {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: var(--space-2);
  min-height: 124px;
  padding: var(--space-2);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: var(--radius-card);
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(255, 255, 255, 0)),
    rgba(23, 26, 33, 0.98);
  box-shadow: var(--shadow-card);
  transition: transform 200ms ease, box-shadow 200ms ease, background 200ms ease, opacity 200ms ease;
}

.tier-card--selected {
  background:
    linear-gradient(180deg, rgba(0, 194, 255, 0.12), rgba(0, 245, 160, 0.08)),
    rgba(15, 19, 26, 0.98);
  box-shadow: var(--shadow-card), var(--shadow-selected);
  transform: scale(1.02);
}

.tier-card--disabled {
  opacity: 0.5;
}

.tier-card__top {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.tier-card__label {
  color: var(--text-primary);
  font-size: 18px;
  font-weight: 500;
  line-height: 1.4;
}

.tier-card--selected .tier-card__label {
  color: var(--brand-primary);
}

.tier-card__price {
  color: var(--brand-primary);
  font-size: 20px;
  font-weight: 600;
  line-height: 1.3;
}

.tier-card__caption {
  color: var(--text-muted);
  font-size: 12px;
  line-height: 1.6;
}
