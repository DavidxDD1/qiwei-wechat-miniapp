<view
  class="tier-card {{selected ? 'tier-card--selected' : ''}} {{disabled ? 'tier-card--disabled' : ''}}"
  bindtap="handleTap"
  hover-class="{{disabled ? '' : 'is-pressing'}}"
  hover-start-time="20"
  hover-stay-time="150"
>
  <view class="tier-card__top">
    <text class="tier-card__label">{{label}}</text>
    <text class="tier-card__price">￥{{price}}</text>
  </view>
  <text class="tier-card__caption" wx:if="{{caption}}">{{caption}}</text>
</view>
