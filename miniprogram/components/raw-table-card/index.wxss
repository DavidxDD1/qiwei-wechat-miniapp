.raw-table-card {
  padding: 18px;
  gap: 16px;
}

.raw-table-card__header {
  display: flex;
  gap: 12px;
  justify-content: space-between;
  align-items: flex-start;
}

.raw-table-card__headline {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.raw-table-card__title {
  color: var(--text-primary);
  font-size: var(--font-size-title);
  font-weight: 700;
}

.raw-table-card__subtitle {
  color: var(--text-secondary);
  font-size: var(--font-size-meta);
  line-height: 1.6;
}

.raw-table-card__summary {
  flex: none;
  padding: 10px 12px;
  border-radius: 16px;
  background: rgba(8, 16, 30, 0.54);
  border: 1px solid rgba(130, 154, 184, 0.14);
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.raw-table-card__summary-value {
  color: var(--text-primary);
  font-size: 16px;
  font-weight: 700;
}

.raw-table-card__summary-label {
  color: var(--text-tertiary);
  font-size: 11px;
}

.raw-table-card__guide {
  padding: 12px 14px;
  border-radius: 16px;
  background: rgba(77, 189, 255, 0.08);
  border: 1px solid rgba(77, 189, 255, 0.12);
}

.raw-table-card__guide-text {
  color: var(--text-secondary);
  font-size: 12px;
  line-height: 1.6;
}

.raw-table-card__entry-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
}

.raw-table-card__scroll {
  width: 100%;
}

.raw-table-card__table {
  min-width: 720px;
  padding-bottom: 4px;
}

.raw-table-card__row {
  display: flex;
  gap: 12px;
  margin-top: 12px;
}

.raw-table-card__row--head {
  margin-top: 0;
  padding-bottom: 8px;
  border-bottom: 1px solid rgba(130, 154, 184, 0.12);
}

.raw-table-card__corner,
.raw-table-card__row-label,
.raw-table-card__head {
  width: 92px;
  flex: none;
  color: var(--text-primary);
  font-size: 13px;
}

.raw-table-card__head {
  text-align: center;
  color: var(--text-secondary);
}

.raw-table-card__cell-list {
  flex: 1;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
  gap: 12px;
}

.raw-table-card__notes {
  padding: 14px;
  border-radius: 18px;
  background: rgba(8, 16, 30, 0.5);
  border: 1px solid rgba(130, 154, 184, 0.14);
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.raw-table-card__notes-title {
  color: var(--text-primary);
  font-size: 14px;
  font-weight: 600;
}

.raw-table-card__note {
  color: var(--text-secondary);
  font-size: 12px;
  line-height: 1.7;
}
