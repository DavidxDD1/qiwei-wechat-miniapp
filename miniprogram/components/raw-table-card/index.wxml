<view class="card raw-table-card" wx:if="{{card}}">
  <view class="raw-table-card__header">
    <view class="raw-table-card__headline">
      <text class="raw-table-card__title">{{card.title}}</text>
      <text class="raw-table-card__subtitle" wx:if="{{card.subtitle}}">{{card.subtitle}}</text>
    </view>
    <view class="raw-table-card__summary">
      <text class="raw-table-card__summary-value" wx:if="{{card.cardType === 'entry-group'}}">{{card.entries.length}} 项</text>
      <text class="raw-table-card__summary-value" wx:else>{{card.rows.length}} × {{card.columns.length}}</text>
      <text class="raw-table-card__summary-label">{{card.cardType === 'entry-group' ? '可选价格项' : '价格矩阵'}}</text>
    </view>
  </view>

  <view class="raw-table-card__guide" wx:if="{{card.cardType !== 'entry-group'}}">
    <text class="raw-table-card__guide-text">左右滑动查看完整表格，点击单元格即可锁定当前方案。</text>
  </view>

  <view wx:if="{{card.cardType === 'entry-group'}}" class="raw-table-card__entry-list">
    <price-cell
      wx:for="{{card.entries}}"
      wx:key="entryId"
      label="{{item.rawLabel}}"
      price-text="{{item.displayPrice}}"
      display-name="{{item.displayName}}"
      service-id="{{item.serviceId}}"
      section-id="{{item.sectionId}}"
      entry-id="{{item.entryId}}"
      selected="{{selectedKey === item.selectionKey}}"
      bind:celltap="handleCellTap"
    ></price-cell>
  </view>

  <scroll-view wx:else scroll-x="true" class="raw-table-card__scroll">
    <view class="raw-table-card__table">
      <view class="raw-table-card__row raw-table-card__row--head">
        <text class="raw-table-card__corner">档位</text>
        <text
          class="raw-table-card__head"
          wx:for="{{card.columns}}"
          wx:key="key"
        >
          {{item.label}}
        </text>
      </view>
      <view
        class="raw-table-card__row"
        wx:for="{{card.rows}}"
        wx:key="rowId"
      >
        <text class="raw-table-card__row-label">{{item.label}}</text>
        <view class="raw-table-card__cell-list">
          <price-cell
            wx:for="{{item.cells}}"
            wx:key="selectionKey"
            label="{{item.label}}"
            price-text="{{item.priceText}}"
            display-name="{{item.displayName}}"
            service-id="{{item.serviceId}}"
            table-id="{{item.tableId}}"
            row-id="{{item.rowId}}"
            column-key="{{item.columnKey}}"
            selected="{{selectedKey === item.selectionKey}}"
            disabled="{{item.disabled}}"
            bind:celltap="handleCellTap"
          ></price-cell>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="raw-table-card__notes" wx:if="{{card.notes && card.notes.length}}">
    <text class="raw-table-card__notes-title">规则说明</text>
    <text class="raw-table-card__note" wx:for="{{card.notes}}" wx:key="*this">- {{item}}</text>
  </view>
</view>
