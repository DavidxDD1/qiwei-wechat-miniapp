.page-hero {
  padding: 22px;
  display: flex;
  flex-direction: column;
  gap: 18px;
}

.page-hero__ambient {
  position: absolute;
  top: -46px;
  right: -26px;
  width: 180px;
  height: 180px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(82, 242, 184, 0.22), transparent 68%);
  pointer-events: none;
}

.page-hero__top {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
}

.page-hero__main {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.page-hero__eyebrow {
  color: var(--brand-highlight);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
}

.page-hero__title {
  color: var(--text-primary);
  font-size: 28px;
  line-height: 1.2;
  font-weight: 700;
}

.page-hero__desc {
  color: var(--text-secondary);
  line-height: 1.8;
}

.page-hero__logo {
  width: 96px;
  height: 96px;
  flex: none;
  padding: 10px;
  border-radius: 24px;
  background: rgba(8, 16, 30, 0.54);
  border: 1px solid rgba(157, 235, 255, 0.18);
}

.page-hero__metrics {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
}

.page-hero__metric {
  padding: 14px 12px;
  border-radius: 18px;
  background: rgba(8, 16, 30, 0.56);
  border: 1px solid rgba(130, 154, 184, 0.16);
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.page-hero__metric-value {
  color: var(--text-primary);
  font-size: 18px;
  font-weight: 700;
}

.page-hero__metric-label {
  color: var(--text-tertiary);
  font-size: 12px;
  line-height: 1.4;
}

.page-hero__actions {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 10px;
}

.page-hero__button {
  flex: 1;
}
