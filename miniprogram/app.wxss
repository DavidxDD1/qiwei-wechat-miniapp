page {
  --bg-primary: #0B0F16;
  --bg-secondary: #111826;
  --bg-card: #151E2D;
  --bg-card-strong: #1A2536;
  --bg-glass: rgba(16, 24, 38, 0.88);
  --bg-spotlight: rgba(0, 194, 255, 0.14);
  --border-color: rgba(128, 152, 185, 0.16);
  --border-strong: rgba(109, 235, 195, 0.28);
  --brand-primary: #52F2B8;
  --brand-secondary: #4DBDFF;
  --brand-highlight: #9DEBFF;
  --text-primary: #F5F9FF;
  --text-secondary: #A2B1C4;
  --text-tertiary: #6E7D92;
  --danger: #FF5A67;
  --warning: #FFCB57;
  --page-padding: 20px;
  --radius-card: 22px;
  --radius-button: 14px;
  --radius-pill: 999px;
  --shadow-card: 0 14px 36px rgba(0, 0, 0, 0.32);
  --shadow-glow: 0 12px 32px rgba(77, 189, 255, 0.18);
  --space-1: 8px;
  --space-2: 16px;
  --space-3: 24px;
  --space-4: 32px;
  --space-section: 18px;
  --space-card: 18px;
  --font-size-label: 11px;
  --font-size-meta: 13px;
  --font-size-heading: 16px;
  --font-size-title: 18px;
  --font-size-display: 24px;
  --font-size-hero: 28px;
  --font-size-body: 14px;
  --font-size-caption: 12px;
  --font-weight-heading: 600;
  --line-height-body: 1.7;
  --line-height-relaxed: 1.75;
  --page-bottom-offset: 188px;
  background:
    radial-gradient(circle at top right, rgba(82, 242, 184, 0.12), transparent 32%),
    linear-gradient(180deg, #0E1520 0%, #0B0F16 48%, #081018 100%);
  color: var(--text-primary);
  font-size: 14px;
}

view,
text,
button,
input,
textarea,
scroll-view {
  box-sizing: border-box;
}

button {
  padding: 0;
  border: none;
  background: transparent;
}

button::after {
  border: none;
}

.page-shell {
  min-height: 100vh;
  padding: 24px var(--page-padding) calc(var(--page-bottom-offset) + env(safe-area-inset-bottom));
  background:
    linear-gradient(180deg, rgba(77, 189, 255, 0.08), transparent 18%),
    linear-gradient(180deg, transparent 0%, rgba(82, 242, 184, 0.04) 100%);
  animation: pageFadeIn 320ms ease both;
}

.page-stack {
  display: flex;
  flex-direction: column;
  gap: var(--space-section);
}

.card {
  position: relative;
  overflow: hidden;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.03), transparent 26%),
    linear-gradient(150deg, rgba(24, 35, 51, 0.96), rgba(16, 24, 38, 0.94));
  border: 1px solid var(--border-color);
  border-radius: var(--radius-card);
  box-shadow: var(--shadow-card);
}

.card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(120deg, rgba(77, 189, 255, 0.08), transparent 32%, rgba(82, 242, 184, 0.06) 100%);
  pointer-events: none;
}

.panel-card {
  padding: var(--space-card);
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.action-stack {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.action-stack > .primary-button,
.action-stack > .ghost-button {
  width: 100%;
}

.muted {
  color: var(--text-secondary);
}

.primary-button {
  min-height: 52px;
  padding: 0 18px;
  border-radius: var(--radius-button);
  color: #07111C;
  background: linear-gradient(90deg, var(--brand-primary), var(--brand-secondary));
  font-size: 14px;
  font-weight: 700;
  text-align: center;
  box-shadow: 0 12px 28px rgba(77, 189, 255, 0.22);
  transition: transform 150ms ease, opacity 150ms ease, box-shadow 150ms ease;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.primary-button[disabled] {
  opacity: 0.5;
  box-shadow: none;
}

.ghost-button {
  min-height: 52px;
  padding: 0 18px;
  border-radius: var(--radius-button);
  border: 1px solid rgba(130, 154, 184, 0.2);
  color: var(--text-primary);
  background: rgba(17, 24, 38, 0.86);
  font-size: 14px;
  font-weight: 600;
  text-align: center;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.is-pressing {
  transform: scale(0.98) !important;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 5px 10px;
  border-radius: var(--radius-pill);
  border: 1px solid rgba(82, 242, 184, 0.16);
  background: rgba(82, 242, 184, 0.08);
  color: var(--brand-primary);
  font-size: 12px;
  line-height: 1.2;
}

.field {
  width: 100%;
  min-height: 48px;
  padding: 12px 14px;
  border: 1px solid rgba(130, 154, 184, 0.16);
  border-radius: 14px;
  background: rgba(10, 16, 27, 0.76);
  color: var(--text-primary);
  font-size: 14px;
}

.field::placeholder {
  color: var(--text-tertiary);
}

@keyframes pageFadeIn {
  from {
    opacity: 0;
    transform: translateY(12px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}
