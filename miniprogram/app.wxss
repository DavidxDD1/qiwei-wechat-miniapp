page {
  --bg-primary: #0F1115;
  --bg-card: #171A21;
  --border-color: #2A2F3A;
  --brand-primary: #00F5A0;
  --brand-secondary: #00C2FF;
  --text-primary: #FFFFFF;
  --text-secondary: #A0A6B1;
  --danger: #FF4D4F;
  --page-padding: 20px;
  --radius-card: 16px;
  --radius-button: 12px;
  --space-1: 8px;
  --space-2: 16px;
  --space-3: 24px;
  background: #0F1115;
  color: #FFFFFF;
  font-size: 14px;
}

view,
text,
button,
input,
textarea,
scroll-view {
  box-sizing: border-box;
}

button {
  padding: 0;
  border: none;
  background: transparent;
}

button::after {
  border: none;
}

.page-shell {
  min-height: 100vh;
  padding: 24px var(--page-padding) 120px;
  background: #0F1115;
  animation: pageFadeIn 300ms ease both;
}

.card {
  background: linear-gradient(145deg, #171A21, #1C1F27);
  border: 1px solid #2A2F3A;
  border-radius: 16px;
  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.35);
}

.muted {
  color: #A0A6B1;
}

.primary-button {
  height: 48px;
  line-height: 48px;
  border-radius: 12px;
  color: #0F1115;
  background: linear-gradient(90deg, #00F5A0, #00C2FF);
  font-size: 14px;
  font-weight: 600;
  text-align: center;
  transition: transform 150ms ease, opacity 150ms ease;
}

.primary-button[disabled] {
  opacity: 0.5;
}

.ghost-button {
  height: 48px;
  line-height: 48px;
  border-radius: 12px;
  border: 1px solid #2A2F3A;
  color: #FFFFFF;
  background: #171A21;
  font-size: 14px;
  text-align: center;
}

.is-pressing {
  transform: scale(0.98) !important;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 4px 10px;
  border-radius: 999px;
  background: rgba(0, 245, 160, 0.12);
  color: #00F5A0;
  font-size: 12px;
}

.field {
  width: 100%;
  min-height: 48px;
  padding: 12px 14px;
  border: 1px solid #2A2F3A;
  border-radius: 12px;
  background: #171A21;
  color: #FFFFFF;
  font-size: 14px;
}

.field::placeholder {
  color: #A0A6B1;
}

@keyframes pageFadeIn {
  from {
    opacity: 0;
  }

  to {
    opacity: 1;
  }
}
