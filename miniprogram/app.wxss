page {
  min-height: 100%;
  background: #000000;
  color: #ffffff;
}

view,
text,
button,
input {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 48rpx 32rpx 56rpx;
  background: #000000;
}

.panel {
  padding: 32rpx;
  border: 2rpx solid #1db954;
  border-radius: 20rpx;
  background: #0f0f0f;
}

.section {
  margin-top: 28rpx;
}

.section-title {
  display: block;
  margin-bottom: 20rpx;
  color: #8ef0b1;
  font-size: 30rpx;
  font-weight: 600;
}

.muted {
  color: #a9a9a9;
  font-size: 26rpx;
}

.price {
  color: #1db954;
  font-size: 40rpx;
  font-weight: 700;
}

.option-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option-btn {
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 14rpx;
  background: #14301e;
  color: #dfffe9;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 88rpx;
  text-align: center;
}

.option-btn--active {
  background: #1db954;
  color: #041108;
}

.primary-btn {
  width: 100%;
  min-height: 92rpx;
  margin-top: 36rpx;
  border-radius: 14rpx;
  background: #1db954;
  color: #041108;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 92rpx;
}

.primary-btn--disabled {
  background: #274231;
  color: #7e9a88;
}

button {
  padding: 0;
  border: none;
}

button::after {
  border: none;
}

.input-field {
  width: 100%;
  height: 92rpx;
  margin-top: 12rpx;
  padding: 0 24rpx;
  border: 2rpx solid #1db954;
  border-radius: 14rpx;
  background: #111111;
  color: #ffffff;
  font-size: 28rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 18rpx;
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid #1c1c1c;
}

.summary-label {
  color: #a9a9a9;
  font-size: 26rpx;
}

.summary-value {
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}
